# --- Required ---
BITBUCKET_URL=https://bitbucket.company.com
BITBUCKET_TOKEN=
BITBUCKET_WEBHOOK_SECRET=
GITHUB_TOKEN=

# --- Review behavior ---
# REVIEW_AUTO_REVIEW_AUTHORS=           # comma-separated; empty = review all authors
# REVIEW_MAX_COMMENTS=25
# REVIEW_DIFF_EXTRA_LINES_BEFORE=3      # context lines added before each diff hunk
# REVIEW_DIFF_EXTRA_LINES_AFTER=1       # context lines added after each diff hunk
# REVIEW_DIFF_MAX_EXTRA_LINES_DYNAMIC_CONTEXT=8  # how far above the context window to search for enclosing function/class definition
# REVIEW_DIFF_ALLOW_DYNAMIC_CONTEXT=true          # extend diff context to include enclosing function/class definition
# REVIEW_PROMPT_TEMPLATE=prompts/review.txt
# REVIEW_MENTION_TRIGGER=noergler       # trigger name used as @<trigger> in PR comments
# REVIEW_MENTION_PROMPT_TEMPLATE=prompts/mention.txt
# REVIEW_RAMSAY_AUTHORS=                # comma-separated usernames that get the Gordon Ramsay tone
# REVIEW_TICKET_COMPLIANCE_CHECK=true   # evaluate PR against Jira ticket acceptance criteria

# --- Jira integration (optional, both required to enable) ---
# JIRA_BASE_URL=
# JIRA_TOKEN=
# JIRA_ACCEPTANCE_CRITERIA_PREFIXES=AC,AK,Acceptance Criteria,Acceptance Criterion,Akzeptanzkriterium,Akzeptanzkriterien,DoD,Req

# --- AI model ---
# COPILOT_MODEL=openai/gpt-4.1
# COPILOT_API_URL=https://models.github.ai/inference/chat/completions
# COPILOT_MAX_TOKENS_PER_CHUNK=80000    # max tokens per diff chunk sent to the model

# --- Server ---
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080
